{
  "name": "supportdesk",
  "version": "1.0.0",
  "private": true,
  "description": "SupportDesk — Help Desk system for tickets, customers, SLA and knowledge base.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @supportdesk/web dev",
    "dev:api": "pnpm --filter @supportdesk/api dev",
    "build": "pnpm -r build",
    "start": "pnpm -r --parallel start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @supportdesk/api prisma:migrate",
    "db:seed": "pnpm --filter @supportdesk/api db:seed",
    "db:reset": "pnpm --filter @supportdesk/api db:reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
