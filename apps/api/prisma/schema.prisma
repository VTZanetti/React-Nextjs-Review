generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  AGENT
  CUSTOMER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketCategory {
  SISTEMA
  FINANCEIRO
  ACESSO
  BUG
  SOLICITACAO
  INTEGRACAO
  NOTA_FISCAL
  OUTRO
}

enum KnowledgeVisibility {
  PUBLIC
  INTERNAL
}

enum TicketEventType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  MESSAGE_SENT
  RESOLVED
  REOPENED
  CANCELLED
}

model User {
  id             String          @id @default(cuid())
  name           String
  email          String          @unique
  passwordHash   String
  role           UserRole        @default(AGENT)
  customerId     String?         @unique
  customer       Customer?       @relation("CustomerUser", fields: [customerId], references: [id])
  assignedTickets Ticket[]       @relation("AssignedTickets")
  messages       TicketMessage[]
  events         TicketEvent[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Customer {
  id        String         @id @default(cuid())
  name      String
  company   String?
  email     String         @unique
  phone     String?
  status    CustomerStatus @default(ACTIVE)
  user      User?          @relation("CustomerUser")
  tickets   Ticket[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Ticket {
  id          String          @id @default(cuid())
  protocol    String          @unique
  title       String
  description String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)
  category    TicketCategory  @default(OUTRO)
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id])
  assigneeId  String?
  assignee    User?           @relation("AssignedTickets", fields: [assigneeId], references: [id])
  messages    TicketMessage[]
  events      TicketEvent[]
  slaDueAt    DateTime
  resolvedAt  DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([customerId])
  @@index([assigneeId])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

model TicketEvent {
  id        String          @id @default(cuid())
  ticketId  String
  ticket    Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type      TicketEventType
  payload   Json?
  authorId  String?
  author    User?           @relation(fields: [authorId], references: [id])
  createdAt DateTime        @default(now())

  @@index([ticketId])
}

model KnowledgeArticle {
  id         String              @id @default(cuid())
  title      String
  slug       String              @unique
  category   String
  content    String
  visibility KnowledgeVisibility @default(PUBLIC)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([category])
  @@index([visibility])
}
